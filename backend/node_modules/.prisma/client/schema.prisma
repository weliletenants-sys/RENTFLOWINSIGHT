generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TENANT
  AGENT
  LANDLORD
  SUPPORTER
  ADMIN
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  FUNDED
  COMPLETED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  RENT_PAYMENT
  INVESTMENT
  ROI_PAYMENT
  FEE
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  phone          String?   @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           Role      @default(TENANT)
  verification   String    @default("UNVERIFIED")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  wallet         Wallet?
  rentRequests   RentRequest[]
  repayments     Repayment[]
  propertiesOwned Property[]   @relation("LandlordProperties")
  propertiesRented Property[]  @relation("TenantProperties")
  
  // As Agent
  assignedTenants User[]     @relation("AgentTenants")
  assignedAgent   User?      @relation("AgentTenants", fields: [agentId], references: [id])
  agentId         String?
  collections     AgentCollection[]
  
  // As Supporter
  portfolio       InvestorPortfolio?
  notifications   Notification[]
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Decimal  @default(0.00) @db.Decimal(10, 2)
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Double-entry relations
  credits   Transaction[]  @relation("WalletCredits")
  debits    Transaction[]  @relation("WalletDebits")
}

// Double-Entry Ledger System
model Transaction {
  id              String   @id @default(uuid())
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("USD")
  type            TransactionType
  description     String?
  referenceId     String?  // Links to RentRequest, Repayment, etc
  
  // The wallet receiving funds
  creditWalletId  String
  creditWallet    Wallet   @relation("WalletCredits", fields: [creditWalletId], references: [id])
  
  // The wallet losing funds
  debitWalletId   String
  debitWallet     Wallet   @relation("WalletDebits", fields: [debitWalletId], references: [id])
  
  createdAt       DateTime @default(now())
}

model Property {
  id          String   @id @default(uuid())
  address     String
  city        String
  country     String
  landlordId  String
  landlord    User     @relation("LandlordProperties", fields: [landlordId], references: [id])
  tenantId    String?
  tenant      User?    @relation("TenantProperties", fields: [tenantId], references: [id])
  rentAmount  Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requests    RentRequest[]
}

model RentRequest {
  id             String        @id @default(uuid())
  tenantId       String
  tenant         User          @relation(fields: [tenantId], references: [id])
  propertyId     String
  property       Property      @relation(fields: [propertyId], references: [id])
  amountRequired Decimal       @db.Decimal(10, 2)
  status         RequestStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  repayments     Repayment[]
  investments    InvestmentTransaction[]
}

model Repayment {
  id             String       @id @default(uuid())
  requestId      String
  request        RentRequest  @relation(fields: [requestId], references: [id])
  tenantId       String
  tenant         User         @relation(fields: [tenantId], references: [id])
  amount         Decimal      @db.Decimal(10, 2)
  dueDate        DateTime
  status         RequestStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
}

model InvestorPortfolio {
  id             String   @id @default(uuid())
  supporterId    String   @unique
  supporter      User     @relation(fields: [supporterId], references: [id])
  totalInvested  Decimal  @default(0.00) @db.Decimal(10, 2)
  totalReturns   Decimal  @default(0.00) @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  investments    InvestmentTransaction[]
}

model InvestmentTransaction {
  id             String            @id @default(uuid())
  portfolioId    String
  portfolio      InvestorPortfolio @relation(fields: [portfolioId], references: [id])
  requestId      String
  request        RentRequest       @relation(fields: [requestId], references: [id])
  amount         Decimal           @db.Decimal(10, 2)
  expectedRoi    Decimal           @db.Decimal(5, 2)
  status         RequestStatus     @default(PENDING)
  createdAt      DateTime          @default(now())
}

model AgentCollection {
  id             String   @id @default(uuid())
  agentId        String
  agent          User     @relation(fields: [agentId], references: [id])
  amount         Decimal  @db.Decimal(10, 2)
  tenantName     String
  gpsLat         Float?
  gpsLng         Float?
  status         String   @default("LOGGED")
  createdAt      DateTime @default(now())
}

model Notification {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  title          String
  message        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
}
