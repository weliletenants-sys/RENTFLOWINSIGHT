generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  WALLET
  CASH
  MOBILE_MONEY
}

model Wallets {
  id         String   @id @default(uuid())
  account_id String   @unique
  balance    Float    @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user_id        String?
  locked_balance Decimal @default(0)
  currency       String  @default("UGX")

  @@map("wallets")
}

model LedgerTransactions {
  id                   String  @id @default(uuid())
  idempotency_key      String? @unique
  approved_by          String?
  category             String
  created_at           String
  description          String?
  initiated_by         String?
  source_id            String?
  source_table         String?
  transaction_group_id String?

  @@map("ledger_transactions")
}

model GeneralLedger {
  id               String   @id @default(uuid())
  transaction_id   String // Groups double-entry pairs
  account_id       String // Generic owner reference
  entry_type       String // 'debit' or 'credit'
  amount           Float
  category         String
  description      String?
  linked_party     String?
  reference_id     String?
  running_balance  Float?
  source_id        String?
  source_table     String
  transaction_date String?
  from_bucket      String?
  to_bucket        String?
  role_type        String?
  scope            String?
  account_type     String?
  created_at       DateTime @default(now())

  @@map("general_ledger")
}

model AuditLogs {
  id          String  @id @default(uuid())
  metadata    Json?
  action_type String?
  created_at  String?
  record_id   String?
  table_name  String?
  user_id     String?
  actor_role  String?
  ip_address  String?
  target_id   String?
  user_agent  String?

  @@map("audit_logs")
}

model AgentAdvanceLedger {
  id               String   @id @default(uuid())
  advance_id       String
  date             DateTime
  opening_balance  Decimal  @default(0)
  interest_accrued Decimal  @default(0)
  amount_deducted  Decimal  @default(0)
  closing_balance  Decimal  @default(0)
  deduction_status String
  created_at       DateTime @default(now())

  @@map("agent_advance_ledger")
}

