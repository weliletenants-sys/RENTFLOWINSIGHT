  @@map("staff_audit_logs")
}

model Sessions {
  id          String   @id @default(uuid())
  user_id     String
  token       String   @unique
  device_info String?
  ip_address  String?
  is_revoked  Boolean  @default(false)
  expires_at  DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([user_id])
  @@map("sessions")
}

model SystemConfigs {
  id          String   @id @default(uuid())
  version     Int      @default(1)
  config_data Json
  changed_by  String
  created_at  DateTime @default(now())

  @@map("system_configs")
}

model ImpersonationLogs {
  id             String   @id @default(uuid())
  super_admin_id String
  target_role    String
  mode           String
  reason         String?
  created_at     DateTime @default(now())

  @@map("impersonation_logs")
}

model VirtualOpportunities {
  id            String  @id @default(uuid())
  name          String
  location      String
  image_url     String?
  rent_required Float
  bedrooms      Int
  status        String  @default("available")
  created_at    String
  updated_at    String

  @@map("virtual_opportunities")
}

model PayoutMethods {
  id             String   @id @default(uuid())
  user_id        String
  provider       String // e.g., "MTN Mobile Money", "Bank Wire"
  account_name   String // Legal Name on Account
  account_number String // MSISDN or Bank Account
  is_primary     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([user_id])
  @@map("payout_methods")
}

model FunderSettings {
  id          String   @id @default(uuid())
  user_id     String   @unique
  reward_mode String   @default("compound") // "compound" or "payout"
  updated_at  DateTime @updatedAt

  @@map("funder_settings")
}

model FunderPortfolios {
  id             String   @id @default(uuid())
  user_id        String
  portfolio_id   String   @unique // e.g., "WPF-7291"
  funding_date   DateTime @default(now())
  active_capital Float
  roi_rate       String // e.g., "15% Standard"
  earned_rewards Float    @default(0)

  @@index([user_id])
  @@map("funder_portfolios")
}

model FunderProxyMandates {
  id          String    @id @default(uuid())
  funder_id   String
  agent_id    String
  agent_name  String?
  agent_code  String?
  daily_limit Float
  status      String    @default("active") // active, revoked
  revoked_at  DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@index([funder_id])
  @@map("funder_proxy_mandates")
}

model TenantGamification {
  id                    String @id @default(uuid())
  tenant_id             String @unique
  target_goal           Float
  current_savings       Float
  payment_streak_months Float
  created_at            String
  updated_at            String

  @@map("tenant_gamification")
}

model GamificationTrophies {
  id          String  @id @default(uuid())
  tenant_id   String
  title       String
  description String
  icon        String
  unlocked    Boolean
  unlocked_at String?

  @@map("gamification_trophies")
}

model SavingsHistory {
  id        String @id @default(uuid())
  tenant_id String
  month     String
  savings   Float?
  projected Float

  @@map("savings_history")
}

model AgentServiceCentres {
  id                   String  @id @default(uuid())
  agent_id             String
  photo_url            String
  latitude             Float
  longitude            Float
  location_description String
  status               String  @default("PENDING")
  created_at           String
  approved_at          String?
  approved_by          String?

  @@map("agent_service_centres")
}

model AgentBonuses {
  id         String  @id @default(uuid())
  agent_id   String
  bonus_type String
  amount     Float
  status     String  @default("PENDING")
  created_at String
  paid_at    String?

  @@map("agent_bonuses")
}

model PortfolioRentPledges {
  id              String @id @default(uuid())
  portfolio_id    String
  rent_request_id String
  assigned_amount Float
  created_at      String

  @@map("portfolio_rent_pledges")
}

model SystemRoles {
  id   String @id @default(uuid())
  name String @unique

  parent_id String?
  parent    SystemRoles?  @relation("RoleHierarchy", fields: [parent_id], references: [id])
  children  SystemRoles[] @relation("RoleHierarchy")

  permissions RolePermissions[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("system_roles")
}

model Permissions {
  id              String            @id @default(uuid())
  action          String // e.g. "manage"
  subject         String // e.g. "all", "Dashboard", "Users"
  system_name     String?           @unique // e.g. "manage_all", equivalent to Spatie's "name"
  description     String?
  rolePermissions RolePermissions[]
  created_at      DateTime          @default(now())

  @@unique([action, subject])
  @@map("permissions")
}

model RolePermissions {
  id            String @id @default(uuid())
  role_id       String
  permission_id String

  role       SystemRoles @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  granted_at DateTime    @default(now())

  @@unique([role_id, permission_id])
  @@map("role_permissions")
}

model IdempotencyKeys {
  key        String   @id
  response   Json?
  status     String   @default("processing") // 'processing', 'completed', 'error'
  created_at DateTime @default(now())
  expires_at DateTime @default(dbgenerated("NOW() + interval '24 hours'"))

  @@map("idempotency_keys")
}



model ProcessedEvents {
  event_id   String   @id
  created_at DateTime @default(now())

  @@map("processed_events")
}

model RiskLog {
  id              String   @id @default(uuid())
  event_id        String   @unique
  idempotency_key String?  @unique
  user_id         String
  action          String
  amount          Float?
  score           Int
  decision        String
  rule_version    String   @default("1.0")
  reasons         String[]
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([user_id, createdAt])
  @@map("risk_logs")
}

model RiskReview {
  id                 String    @id @default(uuid())
  event_id           String    @unique
  idempotency_key    String?   @unique
  user_id            String
  action             String
  amount             Float?
  status             String    // PENDING | APPROVED_PENDING_EXECUTION | APPROVED | COMPLETED | REJECTED | FAILED_PERMANENTLY
  reasons            String[]
  execution_attempts Int       @default(0)
  last_execution_at  DateTime?
  locked_at          DateTime?
  locked_by          String?
  last_heartbeat_at  DateTime?
  createdAt          DateTime  @default(now())
  decidedAt          DateTime?
  decidedBy          String?

  @@map("risk_reviews")
}

// ------------------------------------------------------------------------------------
// TRUE FINANCIAL LEDGER LAYER (v2 - LIVE DATA SAFE)
// ------------------------------------------------------------------------------------

model FinancialAccounts {
  id         String   @id @default(uuid())
  user_id    String?
  type       String   // e.g., WALLET, ESCROW, SUSPENSE, SYSTEM
  balance    Float    @default(0)
  currency   String?  @default("UGX")
  status     String   @default("ACTIVE") // ACTIVE, FROZEN
  created_at DateTime @default(now())

  entries FinancialEntries[]

  @@map("financial_accounts")
}

model FinancialTransactions {
  id              String   @id @default(uuid())
  idempotency_key String   @unique
  status          String   // PENDING, COMPLETED, FAILED
  reference       String?  // RENT_PAYMENT, BACKFILL
  metadata        Json?
  created_at      DateTime @default(now())

  entries FinancialEntries[]

  @@map("financial_transactions")
}

model FinancialEntries {
  id             String   @id @default(uuid())
  transaction_id String
  account_id     String
  amount         Float    // Absolute unsigned amount
  type           String   // DEBIT | CREDIT
  created_at     DateTime @default(now())

  transaction FinancialTransactions @relation(fields: [transaction_id], references: [id])
  account     FinancialAccounts     @relation(fields: [account_id], references: [id])

  @@map("financial_entries")
}

model PaymentIntents {
  id                     String   @id @default(uuid())
  user_id                String
  amount                 Float
  status                 String   // INITIATED, PROCESSING, COMPLETED, FAILED
  risk_review_id         String?
  idempotency_key        String   @unique
  source_account_id      String?
  destination_account_id String?
  reference              String?
  metadata               Json?
  created_at             DateTime @default(now())

  @@map("payment_intents")
}
