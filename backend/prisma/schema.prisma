  updated_at           DateTime @default(now())
  registration_fee     Decimal? @default(0)
  access_fee           Decimal? @default(0)
  access_fee_collected Decimal? @default(0)
  access_fee_status    String?
  monthly_rate         Decimal

  @@map("agent_advances")
}

